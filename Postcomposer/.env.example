# ─── Frontend Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Backend API URL ────────────────────────────────────────────
# In development: leave empty — Vite proxy handles /api/* automatically.
# In production (Vercel): set to your Render service URL.
VITE_API_URL=https://YOUR_APP_NAME.onrender.com

# ── Tenor GIF API (optional) ──────────────────────────────────
# Get a free key at: https://developers.google.com/tenor/guides/quickstart
# Without this, the built-in fallback GIF library is used.
VITE_TENOR_API_KEY=
