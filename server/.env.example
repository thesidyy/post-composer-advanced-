# ─── Server Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── MongoDB Atlas ──────────────────────────────────────────────
# Get this from: Atlas → Cluster → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/

# Optional: specify a DB name (defaults to "postcomposer")
DB_NAME=postcomposer

# ── Cloudinary ─────────────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Server ─────────────────────────────────────────────────────
PORT=3001

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In production, set to your Vercel deployment URL(s)
CORS_ORIGIN=http://localhost:5173,https://YOUR_APP.vercel.app
